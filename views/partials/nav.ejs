<%
  const isLoggedIn = typeof currentUser !== 'undefined' && currentUser;
  const safeSession = typeof session !== 'undefined' ? session : {};
%>

<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="brand">
      <span class="brand-mark">DA</span>
      <span>DevArena</span>
    </a>

    <div class="nav-links">
      <% if (!isLoggedIn) { %>
        <a href="/login">Login</a>
        <a href="/signup" class="nav-cta">Sign Up</a>
      <% } else { %>
        <a href="/dashboard/devproof">DevProof</a>
        <a href="/dashboard/quickhire">QuickHire</a>
        <a href="/dashboard/scrimlink">ScrimLink</a>
        <a href="/dashboard/profile">Profile</a>
        <a href="/messages">Inbox</a>

        <% if (safeSession.role === 'admin') { %>
          <a href="/admin">Admin</a>
        <% } %>

        <a href="/logout" class="nav-cta">Logout</a>
      <% } %>
    </div>
  </div>
</nav>
