<%- include('../partials/head', { title }) %>
<main class="flex-1 p-4 container mx-auto">
  <h1 class="text-3xl font-bold mb-4">Conversation</h1>
  <% if (otherUser) { %>
    <p class="mb-4 text-gray-400">You are chatting with <%= otherUser.username %></p>
  <% } %>
  <div class="mb-6 space-y-3 max-h-96 overflow-y-auto p-4 bg-secondary rounded">
    <% messages.forEach(function(msg) { %>
      <div class="<%= msg.sender.toString() === currentUser ? 'text-right' : 'text-left' %>">
        <div class="inline-block bg-primary p-2 rounded">
          <p><%= msg.content %></p>
          <p class="text-xs text-gray-500 mt-1"><%= new Date(msg.createdAt).toLocaleString() %></p>
        </div>
      </div>
    <% }); %>
    <% if (messages.length === 0) { %>
      <p>No messages yet.</p>
    <% } %>
  </div>
  <form action="/messages/<%= thread._id %>" method="POST" class="flex space-x-2">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <input type="text" name="content" class="flex-grow p-2 rounded text-black" placeholder="Type your message" required maxlength="2000" />
    <button type="submit" class="bg-accent text-white px-4 rounded hover:bg-blue-600">Send</button>
  </form>
</main>
<%- include('../partials/footer') %>