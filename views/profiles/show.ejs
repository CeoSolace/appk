<%- include('../partials/head', { title }) %>

<main class="min-h-screen bg-[#0a0d12] text-white">
  <div class="mx-auto w-full max-w-4xl px-4 py-10 sm:px-6">

    <!-- PROFILE CARD -->
    <section class="overflow-hidden rounded-3xl border border-white/10 bg-[#0f141b] shadow-lg">

      <% if (profile && profile.banner && profile.banner.url) { %>
        <div class="h-44 w-full">
          <img src="<%= profile.banner.url %>" class="h-full w-full object-cover" />
        </div>
      <% } else { %>
        <div class="h-20 w-full border-b border-white/5 bg-[#0c1117]"></div>
      <% } %>

      <div class="px-6 pb-6">

        <!-- TOP ROW -->
        <div class="-mt-10 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">

          <div class="flex items-end gap-4">
            <% if (profile && profile.avatar && profile.avatar.url) { %>
              <img src="<%= profile.avatar.url %>" class="h-24 w-24 rounded-full border-4 border-[#0f141b] object-cover" />
            <% } else { %>
              <div class="h-24 w-24 rounded-full border-4 border-[#0f141b] bg-[#1a2230] flex items-center justify-center">
                <span class="text-2xl font-black"><%= user.username.charAt(0).toUpperCase() %></span>
              </div>
            <% } %>

            <div>
              <h1 class="text-2xl font-bold sm:text-3xl">
                <%= profile.displayName || user.username %>
              </h1>

              <% if (user.username === 'itsnicbtw' || user.username === 'ceosolace') { %>
                <span class="mt-2 inline-block rounded-full border border-yellow-500/20 bg-yellow-500/10 px-3 py-1 text-xs font-bold text-yellow-300">
                  Founder
                </span>
              <% } %>
            </div>
          </div>

          <% if (currentUser && currentUser !== user._id.toString()) { %>
            <a href="/messages/new/<%= user._id %>"
              class="rounded-lg border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold hover:bg-white/10 transition">
              Message
            </a>
          <% } %>
        </div>

        <!-- INFO -->
        <div class="mt-6 space-y-3">
          <% if (profile && profile.location) { %>
            <p class="text-sm text-white/50"><%= profile.location %></p>
          <% } %>

          <% if (profile && profile.bio) { %>
            <p class="max-w-2xl text-sm text-white/80"><%= profile.bio %></p>
          <% } %>

          <p class="text-xs text-white/40">/<%= user.username %></p>

          <% if (profile && profile.tags && profile.tags.length) { %>
            <div class="flex flex-wrap gap-2 pt-2">
              <% profile.tags.forEach(tag => { %>
                <span class="rounded-md border border-white/10 bg-white/5 px-2.5 py-1 text-xs text-white/70">
                  <%= tag %>
                </span>
              <% }) %>
            </div>
          <% } %>
        </div>

        <!-- SOCIALS -->
        <% if (profile && profile.socials) { %>
          <div class="mt-8 grid gap-2">
            <% if (profile.socials.website) { %>
              <a href="<%= profile.socials.website %>" target="_blank"
                class="rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-center text-sm font-semibold hover:bg-white/10">
                Website
              </a>
            <% } %>

            <% if (profile.socials.github) { %>
              <a href="<%= profile.socials.github %>" target="_blank"
                class="rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-center text-sm font-semibold hover:bg-white/10">
                GitHub
              </a>
            <% } %>

            <% if (profile.socials.linkedin) { %>
              <a href="<%= profile.socials.linkedin %>" target="_blank"
                class="rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-center text-sm font-semibold hover:bg-white/10">
                LinkedIn
              </a>
            <% } %>

            <% if (profile.socials.twitter) { %>
              <a href="<%= profile.socials.twitter %>" target="_blank"
                class="rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-center text-sm font-semibold hover:bg-white/10">
                Twitter / X
              </a>
            <% } %>
          </div>
        <% } %>

      </div>
    </section>

    <!-- CONTENT SECTIONS -->
    <div class="mt-6 space-y-6">

      <!-- PROJECTS -->
      <% if (projects && projects.length && (!profile.visibility || profile.visibility.showProjects !== false)) { %>
        <section class="rounded-2xl border border-white/10 bg-[#0f141b] p-5">
          <h2 class="text-lg font-bold">Projects</h2>

          <div class="mt-4 grid gap-3">
            <% projects.forEach(project => { %>
              <a href="/projects/<%= project.slug %>"
                class="rounded-lg border border-white/10 bg-[#0c1117] p-4 hover:bg-[#121923] transition">
                <h3 class="font-semibold"><%= project.name %></h3>
                <% if (project.description) { %>
                  <p class="mt-1 text-sm text-white/60"><%= project.description %></p>
                <% } %>
              </a>
            <% }) %>
          </div>
        </section>
      <% } %>

      <!-- HIRE -->
      <% if (hire && hire.isActive && (!profile.visibility || profile.visibility.showHire !== false)) { %>
        <section class="rounded-2xl border border-white/10 bg-[#0f141b] p-5">
          <h2 class="text-lg font-bold">Available for Work</h2>

          <% if (hire.skills && hire.skills.length) { %>
            <div class="mt-3 flex flex-wrap gap-2">
              <% hire.skills.forEach(skill => { %>
                <span class="rounded-md bg-white/5 px-2.5 py-1 text-xs text-white/70">
                  <%= skill %>
                </span>
              <% }) %>
            </div>
          <% } %>

          <div class="mt-4 text-sm text-white/60 space-y-1">
            <% if (hire.pricing) { %><p>Pricing: <%= hire.pricing %></p><% } %>
            <% if (hire.availability) { %><p>Availability: <%= hire.availability %></p><% } %>
          </div>

          <a href="/hire/<%= user.username %>"
            class="mt-4 block rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-center font-semibold hover:bg-white/10">
            View Services
          </a>
        </section>
      <% } %>

      <!-- TEAMS -->
      <% if (teams && teams.length && (!profile.visibility || profile.visibility.showTeams !== false)) { %>
        <section class="rounded-2xl border border-white/10 bg-[#0f141b] p-5">
          <h2 class="text-lg font-bold">Teams</h2>

          <div class="mt-4 grid gap-3">
            <% teams.forEach(team => { %>
              <a href="/teams/<%= team.slug %>"
                class="rounded-lg border border-white/10 bg-[#0c1117] p-4 hover:bg-[#121923] transition">
                <h3 class="font-semibold"><%= team.name %></h3>
                <% if (team.description) { %>
                  <p class="mt-1 text-sm text-white/60"><%= team.description %></p>
                <% } %>
              </a>
            <% }) %>
          </div>
        </section>
      <% } %>

    </div>

  </div>
</main>

<%- include('../partials/footer') %>
