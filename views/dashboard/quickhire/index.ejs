<%- include('../../partials/head', { title }) %>
<main class="flex-1 p-4 container mx-auto">
  <h1 class="text-3xl font-bold mb-4">QuickHire Profile</h1>
  <% if (errors && errors.length) { %>
    <div class="bg-red-600 text-white p-2 mb-4 rounded">
      <% errors.forEach(function(error) { %>
        <p><%= error.msg %></p>
      <% }); %>
    </div>
  <% } %>
  <form action="/dashboard/quickhire" method="POST" class="space-y-4 bg-secondary/80 p-6 rounded-lg shadow-lg">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="flex items-center space-x-2">
      <input type="checkbox" id="isActive" name="isActive" <%= hire.isActive ? 'checked' : '' %> class="h-4 w-4">
      <label for="isActive">Available for hire</label>
    </div>
    <div>
      <label class="block mb-1" for="skills">Skills (comma separated)</label>
      <input type="text" id="skills" name="skills" value="<%= hire.skills ? hire.skills.join(', ') : '' %>" class="w-full p-2 rounded text-black" />
    </div>
    <div>
      <label class="block mb-1" for="categories">Categories (comma separated)</label>
      <input type="text" id="categories" name="categories" value="<%= hire.categories ? hire.categories.join(', ') : '' %>" class="w-full p-2 rounded text-black" />
    </div>
    <div>
      <label class="block mb-1" for="pricing">Pricing</label>
      <input type="text" id="pricing" name="pricing" value="<%= hire.pricing || '' %>" class="w-full p-2 rounded text-black" />
    </div>
    <div>
      <label class="block mb-1" for="availability">Availability</label>
      <input type="text" id="availability" name="availability" value="<%= hire.availability || '' %>" class="w-full p-2 rounded text-black" />
    </div>
    <button type="submit" class="bg-accent text-white py-2 px-4 rounded hover:bg-blue-600">Save</button>
  </form>
  <hr class="my-6 border-gray-600" />
  <h2 class="text-2xl font-bold mb-4">Work Proofs</h2>
  <div class="grid gap-4 md:grid-cols-3">
    <% proofs.forEach(function(proof) { %>
      <div class="bg-secondary p-4 rounded">
        <h3 class="font-semibold mb-2"><%= proof.title %></h3>
        <% if (proof.media && proof.media.url) { %>
          <img src="<%= proof.media.url %>" alt="Proof" class="rounded mb-2">
        <% } %>
        <p class="text-sm text-gray-400"><%= proof.description %></p>
      </div>
    <% }); %>
    <% if (!proofs || proofs.length === 0) { %>
      <p>No proofs uploaded.</p>
    <% } %>
  </div>
</main>
<%- include('../../partials/footer') %>