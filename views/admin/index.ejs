<%- include('../partials/head', { title }) %>
<main class="flex-1 p-4 container mx-auto">
  <h1 class="text-3xl font-bold mb-6">Admin Dashboard</h1>
  <h2 class="text-2xl font-semibold mb-4">Users</h2>
  <div class="overflow-x-auto mb-8">
    <table class="min-w-full text-left text-sm">
      <thead class="bg-secondary">
        <tr>
          <th class="p-2">Username</th>
          <th class="p-2">Email</th>
          <th class="p-2">Role</th>
          <th class="p-2">Suspended</th>
          <th class="p-2">Action</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(function(user) { %>
          <tr class="border-b border-gray-700">
            <td class="p-2"><%= user.username %></td>
            <td class="p-2"><%= user.email %></td>
            <td class="p-2"><%= user.role %></td>
            <td class="p-2"><%= user.isSuspended ? 'Yes' : 'No' %></td>
            <td class="p-2">
              <form action="/admin/users/<%= user._id %>/suspend" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="bg-accent text-white px-3 py-1 rounded hover:bg-blue-600"><%= user.isSuspended ? 'Unsuspend' : 'Suspend' %></button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
    <% if (users.length === 0) { %>
      <p>No users found.</p>
    <% } %>
  </div>
  <h2 class="text-2xl font-semibold mb-4">Reports</h2>
  <div class="space-y-4">
    <% reports.forEach(function(report) { %>
      <div class="bg-secondary p-4 rounded">
        <p><strong>Reporter:</strong> <%= report.reporter %></p>
        <p><strong>Target:</strong> <%= report.targetType %> - <%= report.targetId %></p>
        <p class="mb-2"><strong>Reason:</strong> <%= report.reason %></p>
        <form action="/admin/reports/<%= report._id %>/delete" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="bg-red-600 text-white px-3 py-1 rounded hover:bg-red-700">Delete Report</button>
        </form>
      </div>
    <% }); %>
    <% if (reports.length === 0) { %>
      <p>No reports submitted.</p>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>